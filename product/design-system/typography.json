{
  "_description": "Roamera typography — from Waves & WiFi concept. Two-font system: display serif + clean sans-serif.",

  "fonts": {
    "heading": {
      "family": "Playfair Display",
      "fallback": "serif",
      "weights": [400, 500, 600, 700],
      "italic": true,
      "source": "Google Fonts",
      "import": "https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap",
      "usage": "ALL h1, h2, h3, h4 elements. Also used for: prices (large display numbers), review scores, logo text. Elegant and editorial."
    },
    "body": {
      "family": "DM Sans",
      "fallback": "-apple-system, sans-serif",
      "weights": [400, 500, 600, 700],
      "italic": true,
      "source": "Google Fonts",
      "import": "https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap",
      "usage": "ALL body text, navigation, buttons, labels, descriptions, UI elements. Clean and modern."
    }
  },

  "scale": {
    "hero-title":      { "size": "3.5rem", "weight": 600, "font": "Playfair Display", "line-height": 1.15, "note": "Homepage hero only" },
    "page-title":      { "size": "2.2rem", "weight": 600, "font": "Playfair Display", "line-height": 1.25, "note": "Listing page h1 (property name)" },
    "section-title":   { "size": "1.5rem", "weight": 600, "font": "Playfair Display", "line-height": 1.25, "note": "Section headings (About, Rooms, Reviews, etc.)" },
    "subsection":      { "size": "1.1rem", "weight": 700, "font": "DM Sans", "line-height": 1.3, "note": "Sub-headings within sections (h3)" },
    "card-title":      { "size": "0.95rem", "weight": 700, "font": "DM Sans", "line-height": 1.3, "note": "Room cards, city cards" },
    "price-display":   { "size": "2rem", "weight": 700, "font": "Playfair Display", "note": "Booking card main price, cowork pricing" },
    "price-small":     { "size": "1.6rem", "weight": 700, "font": "Playfair Display", "note": "Cowork pricing cards" },
    "review-score":    { "size": "2rem", "weight": 700, "font": "Playfair Display", "note": "Overall rating display" },
    "body":            { "size": "0.95rem", "weight": 400, "font": "DM Sans", "line-height": 1.6, "color": "gray-600" },
    "body-small":      { "size": "0.9rem", "weight": 400, "font": "DM Sans", "line-height": 1.5 },
    "nav-link":        { "size": "0.85rem", "weight": 500, "font": "DM Sans", "color": "gray-600" },
    "label-uppercase": { "size": "0.72rem", "weight": 600, "font": "DM Sans", "transform": "uppercase", "letter-spacing": "0.05em", "color": "gray-500" },
    "tag":             { "size": "0.75rem", "weight": 600, "font": "DM Sans" },
    "pill":            { "size": "0.68rem", "weight": 500, "font": "DM Sans" },
    "caption":         { "size": "0.8rem", "weight": 400, "font": "DM Sans", "color": "gray-400" },
    "breadcrumb":      { "size": "0.8rem", "weight": 400, "font": "DM Sans", "color": "gray-400" }
  },

  "rules": [
    "Headings (h1-h4) ALWAYS use Playfair Display — never DM Sans for headings",
    "Body text, nav, buttons, labels ALWAYS use DM Sans — never Playfair for UI text",
    "Exception: h3 subsections inside listing sections use DM Sans bold (0.95-1.1rem, weight 700)",
    "Exception: card titles (room cards) use DM Sans bold, NOT Playfair",
    "Price display uses Playfair Display (editorial feel for numbers)",
    "ALL uppercase labels: 0.72rem, weight 600, letter-spacing 0.05em, color gray-500",
    "Tags: 0.75rem weight 600 (sage-light bg + sage text, or cream bg + coral text)",
    "Pills: 0.68rem weight 500 (gray-100 bg + gray-600 text) — smaller than tags",
    "Line height: 1.6 for body, 1.25 for headings, 1.5 for descriptions",
    "Anti-aliasing: -webkit-font-smoothing: antialiased on body"
  ]
}
